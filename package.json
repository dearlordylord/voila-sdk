{
  "name": "@firfi/voila-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Voila grocery search, sessions, and cart workflows",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "prepare": "husky",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm release:check",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "smoke:catalog-search": "tsx test/live/catalog-search.smoke.ts",
    "smoke:cart": "tsx test/live/cart.smoke.ts",
    "smoke:auth-readonly": "tsx test/live/auth-readonly.smoke.ts",
    "auth:capture": "bash scripts/host-auth-capture.sh",
    "drift:audit": "tsx test/live/drift-audit.smoke.ts",
    "fixtures:audit": "node scripts/audit-fixtures.mjs",
    "lint": "find src test -name '*.ts' -print0 | xargs -0 eslint && jscpd src",
    "lint:fix": "find src test -name '*.ts' -print0 | xargs -0 eslint --fix",
    "format": "find src test -name '*.ts' -print0 | xargs -0 eslint --fix --rule '@effect/dprint: error'",
    "check-format": "find src test -name '*.ts' -print0 | xargs -0 eslint --rule '@effect/dprint: error'",
    "circular": "madge --extensions ts --circular src",
    "package:audit": "pnpm build && node scripts/audit-package.mjs",
    "release:check": "pnpm check-all && pnpm package:audit",
    "check-all": "pnpm build && pnpm typecheck && pnpm circular && pnpm lint && pnpm fixtures:audit && pnpm test:coverage"
  },
  "keywords": [
    "voila",
    "groceries",
    "sdk",
    "effect",
    "typescript"
  ],
  "packageManager": "pnpm@10.29.3",
  "author": "firfi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dearlordylord/voila-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/dearlordylord/voila-sdk/issues"
  },
  "homepage": "https://github.com/dearlordylord/voila-sdk#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "effect": "^3.19.15",
    "tough-cookie": "^6.0.0"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.73.1",
    "@effect/vitest": "latest",
    "@eslint/compat": "^2.0.2",
    "@types/node": "^25.1.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "latest",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "latest"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "@parcel/watcher",
      "unrs-resolver"
    ]
  }
}
