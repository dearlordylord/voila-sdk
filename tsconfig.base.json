{
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@firfi/voila-cli": ["packages/voila-cli/src/index.ts"],
      "@firfi/voila-mcp": ["packages/voila-mcp/src/index.ts"],
      "@firfi/voila-sdk": ["packages/voila-sdk/src/index.ts"]
    },
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  }
}
